{
  "name": "short_term_momentum",
  "label": "短线动量选股器 v2",
  "version": 2,
  "horizon": "1-4 weeks",
  "description": "双层架构：基座分（趋势+动量+流动性）确保风控底座，亮点信号（单针洗盘/MACD相位/VCP收缩/K线反转/缠论背驰等）捕捉具体交易机会。任意一个亮点信号触发即值得关注。",
  "concept_keywords": [
    "AI",
    "人工智能",
    "算力",
    "数据中心",
    "电力",
    "核能",
    "半导体",
    "硅光",
    "光通讯",
    "机器人",
    "出海",
    "稀土",
    "政策",
    "并购",
    "重组"
  ],
  "foundation": {
    "min_score": 35,
    "components": [
      {"name": "trend_regime", "weight": 30},
      {"name": "momentum", "weight": 25},
      {"name": "liquidity_volume", "weight": 15},
      {"name": "concept_strength", "weight": 10},
      {"name": "catalyst", "weight": 10},
      {"name": "risk_penalty", "weight": -20}
    ]
  },
  "highlights": [
    {"name": "single_needle_washout", "threshold": 60, "label": "🎯 单针洗盘"},
    {"name": "macd_phase_confirmation", "threshold": 55, "label": "📈 MACD相位确认"},
    {"name": "impulse_confirmation", "threshold": 60, "label": "🔥 砖型反转"},
    {"name": "pullback_setup", "threshold": 50, "label": "🔄 强势回调"},
    {"name": "vcp_pattern", "threshold": 55, "label": "📐 VCP收缩突破"},
    {"name": "candlestick_reversal", "threshold": 60, "label": "🕯️ K线反转形态"},
    {"name": "chan_divergence", "threshold": 55, "label": "📊 缠论背驰"},
    {"name": "bollinger_squeeze", "threshold": 55, "label": "💎 布林收缩"},
    {"name": "volume_price_divergence", "threshold": 60, "label": "📉 量价背离"}
  ],
  "actions": [
    {"condition": "foundation>=55 && highlights>=2", "label": "Strong Watch", "next_step": "多信号共振，加入重点短线观察，等待突破、回踩或事件确认"},
    {"condition": "foundation>=45 && highlights>=1", "label": "Setup Watch", "next_step": "有明确setup信号，等待确认后试仓"},
    {"condition": "foundation>=35 && highlights>=1", "label": "Alert", "next_step": "基座偏弱但有亮点，轻仓博弈或继续观察"},
    {"condition": "foundation>=35", "label": "Base OK", "next_step": "基座合格但暂无亮点信号，持续跟踪等待setup"},
    {"condition": "default", "label": "Avoid", "next_step": "基座不合格，趋势或风险结构不够好，暂不追"}
  ]
}
