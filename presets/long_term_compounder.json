      {"name": "valuation_upside", "weight": 18},
      {"name": "trend_template", "weight": 12},
      {"name": "catalyst", "weight": 8},
      {"name": "risk_penalty", "weight": -22}
    ]
  },
  "highlights": [
    {"name": "vcp_pattern", "threshold": 50, "label": "📐 VCP收缩突破"},
    {"name": "pullback_setup", "threshold": 45, "label": "🔄 强势回调"},
