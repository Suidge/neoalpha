    {"name": "accumulation_quality", "threshold": 55, "label": "🏦 筹码质量"},
    {"name": "bollinger_squeeze", "threshold": 50, "label": "💎 布林收缩"},
    {"name": "volume_price_divergence", "threshold": 55, "label": "📉 量价背离"},
    {"name": "relative_strength", "threshold": 65, "label": "💪 相对强度领先"}
  ],
  "actions": [
    {"condition": "foundation>=65 && highlights>=2", "label": "Thesis Candidate", "next_step": "进入 thesis-tracker 深度更新，并明确反证条件"},
    {"condition": "foundation>=55 && highlights>=1", "label": "DCF Candidate", "next_step": "补充估值模型或可比公司分析"},
    {"condition": "foundation>=40 && highlights>=1", "label": "Watch + Timing", "next_step": "逻辑有线索且有择时信号，浅度跟踪"},
    {"condition": "foundation>=40", "label": "Watchlist Only", "next_step": "逻辑有线索，等待价格、数据或催化剂验证"},
